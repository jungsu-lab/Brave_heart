---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Props = {
	readonly project: CollectionEntry<'projects'>;
};

export async function getStaticPaths() {
	const projects = await getCollection('projects');

	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectStatusLabels: Record<string, string> = {
	Active: '운영 중',
	Complete: '완료',
	Study: '실험 중',
};
---

<BaseLayout title={`jungsu blog | ${project.data.title}`} description={project.data.description}>
	<article>
		<header>
			<p class="eyebrow">프로젝트</p>
			<h1>{project.data.title}</h1>
			<p class="lede">{project.data.description}</p>
			<p class="meta">
				<time datetime={project.data.date.toISOString()}>
					{project.data.date.toLocaleDateString('ko-KR', {
						month: 'long',
						day: 'numeric',
						year: 'numeric',
					})}
				</time>
				{' · '}
				{projectStatusLabels[project.data.status] ?? project.data.status}
			</p>
			<p class="tags-line">역할: {project.data.role}</p>
			<p class="tags-line">스택: {project.data.stack.join(', ')}</p>
			<p class="tags-line">태그: {project.data.tags.join(', ')}</p>
		</header>
		<Content />
	</article>
</BaseLayout>
