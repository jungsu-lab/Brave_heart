---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(firstPost, secondPost) => secondPost.data.date.valueOf() - firstPost.data.date.valueOf(),
);
const studyTags = ['AI', '개발', '디자인', '프롬프트', '워크플로'];
---

<BaseLayout
	title="jungsu blog | 공부 기록"
	description="AI, 개발, 디자인 공부 기록을 모아둔 Study 페이지."
>
	<section class="hero">
		<p class="eyebrow">공부 기록</p>
		<h1>스터디 로그.</h1>
		<p>AI, 개발, 디자인을 공부하면서 직접 이해한 내용만 차분하게 정리합니다.</p>
		<ul class="tag-list" aria-label="공부 주제">
			{studyTags.map((tag) => <li>{tag}</li>)}
		</ul>
	</section>

	<section class="page-section" aria-labelledby="study-notes">
		<div class="section-heading">
			<h2 id="study-notes">공부 노트</h2>
		</div>
		<ul class="archive-list">
			{
				posts.map((post) => (
					<li class="archive-item">
						<time datetime={post.data.date.toISOString()}>
							{post.data.date.toLocaleDateString('ko-KR', {
								month: 'long',
								day: 'numeric',
								year: 'numeric',
							})}
						</time>
						<div>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							<p>{post.data.description}</p>
							<span>{post.data.tags.join(' / ')}</span>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
